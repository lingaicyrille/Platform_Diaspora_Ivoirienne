# ─── Django ───────────────────────────────────────────────
DEBUG=True
SECRET_KEY=change-me-to-a-long-random-string-at-least-50-chars
ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.development

# ─── Database ─────────────────────────────────────────────
POSTGRES_DB=diaspora_db
POSTGRES_USER=diaspora_user
POSTGRES_PASSWORD=change-me
# Inside Docker use host=db; locally use host=localhost
DATABASE_URL=postgresql://diaspora_user:change-me@db:5432/diaspora_db

# ─── Redis ────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Cloudinary ───────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ─── JWT ──────────────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ─── Frontend ─────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXTAUTH_SECRET=change-me-to-a-long-random-string
NEXTAUTH_URL=http://localhost:3000

# ─── CORS ─────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ─── Production server tuning ─────────────────────────────
GUNICORN_WORKERS=2
GUNICORN_TIMEOUT=120
GUNICORN_KEEPALIVE=5
LOG_LEVEL=info
DJANGO_LOG_LEVEL=error
APP_LOG_LEVEL=info
SECURE_SSL_REDIRECT=True

# ─── API rate limiting (production) ───────────────────────
THROTTLE_ANON=60/hour
THROTTLE_USER=1000/hour

# ─── Email (production SMTP) ──────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@diaspora-ivoirienne.com

# ─── Sentry (optional — leave blank to disable) ───────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.05
